{
  "crons": [
    {
      "path": "/api/cron/picks",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/resolve",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/email",
      "schedule": "30 11 * * *"
    }
  ],
  "functions": {
    "app/api/picks/route.js": { "maxDuration": 60 },
    "app/api/cron/picks/route.js": { "maxDuration": 300 },
    "app/api/cron/resolve/route.js": { "maxDuration": 60 },
    "app/api/cron/email/route.js": { "maxDuration": 60 }
  }
}
